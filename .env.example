# Database (local Postgres via Homebrew)
DATABASE_URL=postgresql+asyncpg://user@localhost:5432/sequence_service

# Redis
REDIS_URL=redis://localhost:6379

# Gmail
GMAIL_ENABLED=true
GMAIL_SERVICE_ACCOUNT_FILE=/path/to/credentials/service-account.json
GMAIL_DELEGATED_USER=quinn@telnyx.com

# API
API_HOST=0.0.0.0
API_PORT=8001

# Workers
WORKER_CONCURRENCY=4

# Logging
LOG_LEVEL=INFO

# Tracking
TRACKING_ENABLED=false
TRACKING_BASE_URL=https://track.example.com
